{
  "manifest_version": 3,
  "name": "Rwote",
  "version": "1.0.0",
  "description": "Capture and organize insights from your learning sessions.",
  "permissions": [
    "storage",
    "contextMenus",
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://*.claude.ai/*",
    "https://joqxsbboxmkpcizasdbc.supabase.co/*",
    "https://cdn.jsdelivr.net/*",
    "https://accounts.google.com/*",
    "https://oauth2.googleapis.com/*",
    "https://rwote.app/*",
    "https://www.rwote.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://*.claude.ai/*", "<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open Rwote",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["callback.html"],
      "matches": ["https://*/*"]
    }
  ]
}
