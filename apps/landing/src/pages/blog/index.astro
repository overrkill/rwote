---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export const prerender = true;

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BlogLayout title="Blog" description="Guides and updates from the Rwote team">
  <main class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold text-primary mb-8">Blog</h1>
    <div class="space-y-8">
      {posts.map((post) => (
        <article class="border-b border-border pb-8">
          <a href={`/blog/${post.id}`} class="block group">
            <h2 class="text-xl font-semibold text-primary group-hover:text-accent transition-colors mb-2">
              {post.data.title}
            </h2>
            <p class="text-secondary mb-2">{post.data.description}</p>
            <time class="text-sm text-secondary">
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </a>
        </article>
      ))}
    </div>
  </main>
</BlogLayout>
