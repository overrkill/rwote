---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const readingTime = Math.ceil((post.body?.split(/\s+/).length ?? 400) / 200);
---

<BlogLayout title={post.data.title} description={post.data.description}>
  <main class="max-w-3xl mx-auto px-4 py-16">
    <article>
      <header class="mb-12">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm mb-6 text-secondary dark:text-[#9a9590] hover:text-accent transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to Blog
        </a>
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-primary dark:text-[#faf9f7] leading-tight">
          {post.data.title}
        </h1>
        <p class="text-lg text-secondary dark:text-[#9a9590] mb-6">
          {post.data.description}
        </p>
        <div class="flex items-center gap-4 text-sm text-secondary dark:text-[#9a9590]">
          <time>
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <span class="w-1 h-1 rounded-full bg-secondary dark:bg-[#9a9590]"></span>
          <span>{readingTime} min read</span>
        </div>
      </header>
      
      <div class="prose prose-stone dark:prose-invert max-w-none 
        prose-headings:text-primary dark:prose-headings:text-[#faf9f7] prose-headings:font-semibold
        prose-p:text-secondary dark:prose-p:text-[#9a9590] prose-p:leading-relaxed
        prose-a:text-accent prose-a:no-underline hover:prose-a:underline
        prose-code:bg-surfaceAlt dark:prose-code:bg-[#252422] prose-code:text-primary dark:prose-code:text-[#faf9f7] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:before:content-none prose-code:after:content-none
        prose-pre:bg-surfaceAlt dark:prose-pre:bg-[#1a1917] prose-pre:border prose-pre:border-border dark:prose-pre:border-[#2d2b28]
        prose-li:text-secondary dark:prose-li:text-[#9a9590]
        prose-strong:text-primary dark:prose-strong:text-[#faf9f7]
        prose-blockquote:border-l-accent prose-blockquote:bg-surfaceAlt dark:prose-blockquote:bg-[#1a1917] prose-blockquote:px-6 prose-blockquote:py-4 prose-blockquote:rounded-r-lg">
        <Content />
      </div>
      
      <footer class="mt-16 pt-8 border-t border-border dark:border-[#2d2b28]">
        <a href="/blog" class="inline-flex items-center gap-2 text-accent hover:underline">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          More articles
        </a>
      </footer>
    </article>
  </main>
</BlogLayout>