---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Sign In" description="Sign in to your Rwote account">
  <Header />
  <main class="max-w-md mx-auto px-4 py-16">
    <h1 class="text-2xl font-bold text-primary mb-8 text-center">Sign In</h1>
    <form id="login-form" class="space-y-4">
      <div>
        <label for="email" class="block text-sm font-medium text-primary mb-1">Email</label>
        <input type="email" id="email" name="email" required class="w-full px-4 py-2 rounded-lg border border-border bg-surface text-primary focus:outline-none focus:ring-2 focus:ring-accent" />
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-primary mb-1">Password</label>
        <input type="password" id="password" name="password" required class="w-full px-4 py-2 rounded-lg border border-border bg-surface text-primary focus:outline-none focus:ring-2 focus:ring-accent" />
      </div>
      <div id="error" class="text-red-500 text-sm hidden"></div>
      <button type="submit" class="w-full px-4 py-2 rounded-full font-semibold bg-accent text-white hover:opacity-85 transition-opacity">
        Sign In
      </button>
    </form>
    <p class="mt-6 text-center text-sm text-secondary">
      Don't have an account? <a href="/auth/register" class="text-accent hover:underline">Sign up</a>
    </p>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorEl = document.getElementById('error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errorEl) errorEl.classList.add('hidden');
    
    const formData = new FormData(form);
    const email = formData.get('email');
    const password = formData.get('password');

    try {
      const res = await fetch('https://rwote.com/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      if (res.ok) {
        window.location.href = '/dashboard';
      } else {
        const data = await res.json();
        if (errorEl) {
          errorEl.textContent = data.error || 'Failed to sign in';
          errorEl.classList.remove('hidden');
        }
      }
    } catch {
      // Redirect to web-app for auth
      window.location.href = 'https://rwote.com/auth/login';
    }
  });
</script>
