---
---
<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-bg dark:bg-bg-dark">
  <div class="absolute inset-0 bg-gradient-to-br from-bg via-surfaceAlt to-bg dark:from-bg-dark dark:via-surfaceAlt-dark dark:to-bg-dark"></div>
  <div class="absolute top-20 left-10 w-72 h-72 bg-accent/20 rounded-full blur-[100px] animate-float"></div>
  <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent/10 rounded-full blur-[120px] animate-float" style="animation-delay: 1.5s"></div>
  
  <div class="relative max-w-6xl mx-auto px-4 py-20 grid md:grid-cols-2 gap-12 items-center">
    <div class="animate-fade-up">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surfaceAlt dark:bg-[#252422] border border-border dark:border-[#2d2b28] mb-6">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        <span class="text-xs text-secondary dark:text-[#9a9590]">Now in public beta</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-primary dark:text-[#faf9f7]">
        Capture insights from your <span class="text-accent">learning</span>
      </h1>
      <p class="text-lg md:text-xl mb-10 max-w-xl text-secondary dark:text-[#9a9590]">
        A simple tool for capturing and organizing insights while you learn. 
        Works as a Chrome extension and web app.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="https://app.rwote.com" class="group px-8 py-4 rounded-full font-semibold bg-accent text-white text-center hover:opacity-85 transition-all hover:scale-105 hover:shadow-lg hover:shadow-accent/25 flex items-center justify-center gap-2">
          Get Started Free
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a href="#how-it-works" class="px-8 py-4 rounded-full font-normal bg-surfaceAlt dark:bg-[#252422] text-primary dark:text-[#faf9f7] text-center border border-border dark:border-[#2d2b28] hover:bg-surface dark:hover:bg-[#1a1917] transition-all">
          How It Works
        </a>
      </div>
      
      <p class="mt-8 text-sm text-secondary dark:text-[#9a9590]">
        Also available on <a href="#" class="text-primary dark:text-[#faf9f7] hover:underline">PlayStore</a> & <a href="#" class="text-primary dark:text-[#faf9f7] hover:underline">Chrome Webstore</a>
      </p>
      
      <div class="mt-12 flex items-center gap-6">
        <div class="flex -space-x-2">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 border-2 border-bg dark:border-[#0f0e0d]"></div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 border-2 border-bg dark:border-[#0f0e0d]"></div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-400 to-green-600 border-2 border-bg dark:border-[#0f0e0d]"></div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-orange-400 to-orange-600 border-2 border-bg dark:border-[#0f0e0d]"></div>
        </div>
        <p class="text-sm text-secondary dark:text-[#9a9590]">
          <span class="text-primary dark:text-[#faf9f7] font-semibold">2,000+</span> insights captured
        </p>
      </div>
    </div>
    
    <div class="hidden md:block animate-fade-up" style="animation-delay: 200ms">
      <div class="relative max-w-xl mx-auto transform -rotate-2 hover:-rotate-0 transition-transform duration-700 px-4">
        <!-- Carousel -->
        <div class="relative overflow-hidden rounded-2xl">
          <div id="carousel" class="flex transition-transform duration-700 ease-in-out">
            <!-- Web App Slide -->
            <div class="w-full flex-shrink-0 px-6">
              <!-- Browser bar -->
              <div class="bg-browser-bar dark:bg-browser-bg rounded-t-2xl px-4 py-2 flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <div class="flex-1 ml-2 px-3 py-1 rounded bg-surfaceAlt dark:bg-surfaceAlt-dark text-xs text-secondary dark:text-[#9a9590]">app.rwote.com</div>
              </div>
              <div class="bg-surfaceAlt dark:bg-[#1a1917] rounded-b-2xl border border-border dark:border-[#2d2b28] overflow-hidden shadow-mockup">
                <div class="flex items-center justify-between px-4 py-3 border-b border-border dark:border-[#2d2b28]">
                  <span class="text-lg font-display text-primary dark:text-[#faf9f7]">Rwote</span>
                  <div class="flex items-center gap-2">
                    <span class="text-xs text-secondary dark:text-[#9a9590]">3 notes</span>
                    <svg class="w-5 h-5 text-secondary dark:text-[#9a9590]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                  </div>
                </div>
                <div class="px-4 py-2">
                  <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-surface dark:bg-[#252422]">
                    <svg class="w-4 h-4 text-secondary dark:text-[#9a9590]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-width="2" d="m21 21-4.35-4.35"/>
                    </svg>
                    <span class="text-xs text-secondary dark:text-[#9a9590]">Search notes…</span>
                  </div>
                </div>
                <div class="px-4 pb-2">
                  <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-surface dark:bg-[#252422]">
                    <svg class="w-4 h-4 text-secondary dark:text-[#9a9590]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                    </svg>
                    <span class="text-xs text-secondary dark:text-[#9a9590]">Filter by tag…</span>
                  </div>
                </div>
                <div class="px-4 pb-2 space-y-2">
                  <div class="p-3 rounded-lg bg-surface dark:bg-[#252422] border border-border dark:border-[#2d2b28]">
                    <div class="flex gap-1.5 mb-2">
                      <span class="px-1.5 py-0.5 text-[10px] font-medium rounded-full bg-[#e8f0fe] text-[#3b5bdb]">IDEA</span>
                    </div>
                    <p class="text-sm text-primary dark:text-[#faf9f7]">Ship early, iterate fast</p>
                    <p class="text-[10px] text-secondary dark:text-[#9a9590] mt-1">12 Apr 2026</p>
                  </div>
                  <div class="p-3 rounded-lg bg-surface dark:bg-[#252422] border border-border dark:border-[#2d2b28]">
                    <div class="flex gap-1.5 mb-2">
                      <span class="px-1.5 py-0.5 text-[10px] font-medium rounded-full bg-[#fff0f0] text-[#c8402a]">BOOK</span>
                    </div>
                    <p class="text-sm text-primary dark:text-[#faf9f7]">Build in public</p>
                    <p class="text-[10px] text-secondary dark:text-[#9a9590] mt-1">11 Apr 2026</p>
                  </div>
                </div>
                <div class="px-4 py-3 border-t border-border dark:border-[#2d2b28]">
                  <div class="flex gap-2">
                    <div class="flex-1 px-3 py-2 rounded-lg bg-surface dark:bg-[#252422] text-xs text-secondary dark:text-[#9a9590]">
                      Write your note… use #tag
                    </div>
                    <div class="px-4 py-2 rounded-lg bg-accent text-white text-xs font-medium">
                      Save
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Mobile Slide -->
            <div class="w-full flex-shrink-0 px-6">
              <div class="relative flex justify-center">
                <div class="relative w-[280px] h-[520px] bg-surfaceAlt dark:bg-[#1a1917] rounded-[2rem] border border-border dark:border-[#2d2b28] overflow-hidden shadow-none">
                  <!-- Phone notch -->
                  <div class="h-8 bg-surfaceAlt dark:bg-[#1a1917] flex items-center justify-center">
                    <div class="w-24 h-5 bg-black dark:bg-gray-800 rounded-full"></div>
                  </div>
                  <!-- Header -->
                  <div class="flex items-center justify-between px-4 py-3 border-b border-border dark:border-[#2d2b28]">
                    <span class="text-base font-display text-primary dark:text-[#faf9f7]">Rwote</span>
                    <div class="flex items-center gap-2">
                      <span class="text-[10px] text-secondary dark:text-[#9a9590]">3</span>
                      <svg class="w-4 h-4 text-secondary dark:text-[#9a9590]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                      </svg>
                    </div>
                  </div>
                  <!-- Search -->
                  <div class="px-3 py-2">
                    <div class="flex items-center gap-2 px-2 py-1.5 rounded-lg bg-surface dark:bg-[#252422]">
                      <svg class="w-3 h-3 text-secondary dark:text-[#9a9590]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-width="2" d="m21 21-4.35-4.35"/>
                      </svg>
                      <span class="text-[10px] text-secondary dark:text-[#9a9590]">Search…</span>
                    </div>
                  </div>
                  <!-- Filter -->
                  <div class="px-3 pb-2">
                    <div class="flex gap-1">
                      <span class="px-2 py-0.5 text-[9px] font-medium rounded-full bg-accent text-white">ALL</span>
                      <span class="px-2 py-0.5 text-[9px] rounded-full bg-surface dark:bg-[#252422] text-secondary dark:text-[#9a9590]">IDEA</span>
                      <span class="px-2 py-0.5 text-[9px] rounded-full bg-surface dark:bg-[#252422] text-secondary dark:text-[#9a9590]">BOOK</span>
                    </div>
                  </div>
                  <!-- Notes -->
                  <div class="px-3 space-y-2 h-[340px] overflow-y-auto pb-2">
                    <div class="p-2 rounded-lg bg-surface dark:bg-[#252422] border border-border dark:border-[#2d2b28]">
                      <div class="flex gap-1 mb-1">
                        <span class="px-1 py-0.5 text-[8px] font-medium rounded-full bg-[#e8f0fe] text-[#3b5bdb]">IDEA</span>
                      </div>
                      <p class="text-[11px] text-primary dark:text-[#faf9f7]">Ship early, iterate fast</p>
                    </div>
                    <div class="p-2 rounded-lg bg-surface dark:bg-[#252422] border border-border dark:border-[#2d2b28]">
                      <div class="flex gap-1 mb-1">
                        <span class="px-1 py-0.5 text-[8px] font-medium rounded-full bg-[#fff0f0] text-[#c8402a]">BOOK</span>
                      </div>
                      <p class="text-[11px] text-primary dark:text-[#faf9f7]">Build in public</p>
                    </div>
                    <div class="p-2 rounded-lg bg-surface dark:bg-[#252422] border border-border dark:border-[#2d2b28]">
                      <div class="flex gap-1 mb-1">
                        <span class="px-1 py-0.5 text-[8px] font-medium rounded-full bg-[#f0fdf4] text-[#166534]">QUOTE</span>
                      </div>
                      <p class="text-[11px] text-primary dark:text-[#faf9f7]">Design tokens for consistency</p>
                    </div>
                    <div class="p-2 rounded-lg bg-surface dark:bg-[#252422] border border-border dark:border-[#2d2b28]">
                      <div class="flex gap-1 mb-1">
                        <span class="px-1 py-0.5 text-[8px] font-medium rounded-full bg-[#fef3c7] text-[#92400e]">THOUGHT</span>
                      </div>
                      <p class="text-[11px] text-primary dark:text-[#faf9f7]">The best time to start was yesterday</p>
                    </div>
                  </div>
                  <!-- Input -->
                  <div class="absolute bottom-0 left-0 right-0 px-3 py-3 bg-surfaceAlt dark:bg-[#1a1917] border-t border-border dark:border-[#2d2b28]">
                    <div class="flex gap-1">
                      <div class="flex-1 px-2 py-2 rounded-lg bg-surface dark:bg-[#252422] text-[10px] text-secondary dark:text-[#9a9590]">
                        Write your note… use #tag
                      </div>
                      <div class="px-3 py-2 rounded-lg bg-accent text-white text-[10px] font-medium">
                        +
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const carousel = document.getElementById('carousel') as HTMLElement | null;
  if (carousel) {
    let currentSlide = 0;
    const totalSlides = 2;
    const mockups = carousel.querySelectorAll('.shadow-mockup, .shadow-none');

    function updateSlideShadows() {
      mockups.forEach((el, i) => {
        el.classList.toggle('shadow-mockup', i === currentSlide);
        el.classList.toggle('shadow-none', i !== currentSlide);
      });
    }

    function goToSlide() {
      currentSlide = (currentSlide + 1) % totalSlides;
      carousel.style.transform = `translateX(-${currentSlide * 100}%)`;
      updateSlideShadows();
    }

    updateSlideShadows();
    let autoplay = setInterval(goToSlide, 5000);

    carousel.addEventListener('mouseenter', () => {
      clearInterval(autoplay);
    });

    carousel.addEventListener('mouseleave', () => {
      autoplay = setInterval(goToSlide, 5000);
    });
  }
</script>
