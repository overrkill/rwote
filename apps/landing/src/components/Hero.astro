---
---
<section class="relative min-h-[90vh] flex items-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-[#0f0e0d] via-[#1a1917] to-[#0f0e0d] dark:from-[#0f0e0d] dark:via-[#1a1917] dark:to-[#0f0e0d]"></div>
  <div class="absolute top-20 left-10 w-72 h-72 bg-accent/20 rounded-full blur-[100px] animate-float"></div>
  <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent/10 rounded-full blur-[120px] animate-float" style="animation-delay: 1.5s"></div>
  
  <div class="relative max-w-6xl mx-auto px-4 py-20 grid md:grid-cols-2 gap-12 items-center">
    <div class="animate-fade-up">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surfaceAlt-dark dark:bg-[#252422] border border-border-dark dark:border-[#2d2b28] mb-6">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        <span class="text-xs text-secondary-dark dark:text-[#9a9590]">Now in public beta</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-primary-dark dark:text-[#faf9f7]">
        Capture insights from your <span class="text-accent">learning</span>
      </h1>
      <p class="text-lg md:text-xl mb-10 max-w-xl text-secondary-dark dark:text-[#9a9590]">
        A simple tool for capturing and organizing insights while you learn. 
        Works as a Chrome extension and web app.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="https://app.rwote.com" class="group px-8 py-4 rounded-full font-semibold bg-accent text-white text-center hover:opacity-85 transition-all hover:scale-105 hover:shadow-lg hover:shadow-accent/25 flex items-center justify-center gap-2">
          Get Started Free
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a href="#how-it-works" class="px-8 py-4 rounded-full font-normal bg-surfaceAlt-dark dark:bg-[#252422] text-primary-dark dark:text-[#faf9f7] text-center border border-border-dark dark:border-[#2d2b28] hover:bg-surface-dark dark:hover:bg-[#1a1917] transition-all">
          How It Works
        </a>
      </div>
      <div class="mt-12 flex items-center gap-6">
        <div class="flex -space-x-2">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 border-2 border-[#0f0e0d]"></div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 border-2 border-[#0f0e0d]"></div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-400 to-green-600 border-2 border-[#0f0e0d]"></div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-orange-400 to-orange-600 border-2 border-[#0f0e0d]"></div>
        </div>
        <p class="text-sm text-secondary-dark dark:text-[#9a9590]">
          <span class="text-primary-dark dark:text-[#faf9f7] font-semibold">2,000+</span> insights captured
        </p>
      </div>
    </div>
    
    <div class="hidden md:block animate-fade-up" style="animation-delay: 200ms">
      <div class="relative">
        <div class="absolute inset-0 bg-accent/20 rounded-2xl blur-xl transform rotate-6"></div>
        <div class="relative bg-surfaceAlt-dark dark:bg-[#1a1917] rounded-2xl p-6 shadow-2xl border border-border-dark dark:border-[#2d2b28] transform -rotate-2 hover:rotate-0 transition-transform duration-500">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
            </div>
            <span class="text-sm font-mono text-secondary-dark dark:text-[#9a9590]">rwote.com</span>
          </div>
          <div class="space-y-3">
            <div class="flex gap-2">
              <span class="px-2 py-1 text-xs font-medium rounded-full bg-[#e8f0fe] text-[#3b5bdb]">IDEA</span>
              <span class="px-2 py-1 text-xs font-medium rounded-full bg-[#fff0f0] text-[#c8402a]">BOOK</span>
              <span class="px-2 py-1 text-xs font-medium rounded-full bg-[#f0fdf4] text-[#166534]">QUOTE</span>
            </div>
            <div class="p-3 rounded-lg bg-surface-dark dark:bg-[#252422] border border-border-dark dark:border-[#2d2b28]">
              <p class="text-sm font-medium text-primary-dark dark:text-[#faf9f7]">Ship early, iterate fast</p>
              <p class="text-xs text-secondary-dark dark:text-[#9a9590] mt-1">From the book inspired</p>
            </div>
            <div class="p-3 rounded-lg bg-surface-dark dark:bg-[#252422] border border-border-dark dark:border-[#2d2b28]">
              <p class="text-sm font-medium text-primary-dark dark:text-[#faf9f7]">Build in public</p>
              <p class="text-xs text-secondary-dark dark:text-[#9a9590] mt-1">Great for growing audience</p>
            </div>
            <div class="p-3 rounded-lg bg-surface-dark dark:bg-[#252422] border border-border-dark dark:border-[#2d2b28]">
              <p class="text-sm font-medium text-primary-dark dark:text-[#faf9f7]">Design tokens</p>
              <p class="text-xs text-secondary-dark dark:text-[#9a9590] mt-1">System for consistent UI</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
