---
---
<section id="pricing" class="py-16 bg-surface">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-4 text-primary">
      Simple pricing
    </h2>
    <p class="text-center mb-12 text-secondary">
      Start free. Upgrade when you need cloud sync.
    </p>
    <div class="grid md:grid-cols-2 gap-8 max-w-2xl mx-auto">
      <div class="rounded-xl p-8 bg-bg border border-border">
        <h3 class="text-xl font-semibold mb-2 text-primary">Free</h3>
        <p class="text-3xl font-bold mb-4 text-primary">$0</p>
        <p class="text-sm mb-6 text-secondary">Forever free</p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-2 text-sm text-primary">
            <span class="text-green-500">✓</span>
            Unlimited notes
          </li>
          <li class="flex items-center gap-2 text-sm text-primary">
            <span class="text-green-500">✓</span>
            Browser extension
          </li>
          <li class="flex items-center gap-2 text-sm text-primary">
            <span class="text-green-500">✓</span>
            Select to add
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <span>−</span>
            Local storage only
          </li>
        </ul>
        <a href="/auth/register" class="block w-full px-6 py-2.5 rounded-full text-center bg-surfaceAlt text-primary border border-border hover:bg-surface transition-all">
          Get Extension
        </a>
      </div>

      <div class="rounded-xl p-8 relative bg-bg border-2 border-accent">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 text-xs px-3 py-1 rounded-full bg-accent text-white">
          Pro
        </div>
        <h3 class="text-xl font-semibold mb-2 text-primary">Pro</h3>
        <p class="text-3xl font-bold mb-4 text-primary">$5<span class="text-base font-normal text-secondary">/mo</span></p>
        <p class="text-sm mb-6 text-secondary">or $30 lifetime</p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-2 text-sm text-primary">
            <span class="text-green-500">✓</span>
            Everything in Free
          </li>
          <li class="flex items-center gap-2 text-sm text-primary">
            <span class="text-green-500">✓</span>
            Cloud sync
          </li>
          <li class="flex items-center gap-2 text-sm text-primary">
            <span class="text-green-500">✓</span>
            Access on any device
          </li>
          <li class="flex items-center gap-2 text-sm text-primary">
            <span class="text-green-500">✓</span>
            Automatic backup
          </li>
        </ul>
        <a href="/auth/register" class="block w-full px-8 py-3 rounded-full font-semibold text-center bg-accent text-white hover:opacity-85 transition-opacity">
          Try 7 Days free trial
        </a>
      </div>
    </div>
  </div>
</section>
