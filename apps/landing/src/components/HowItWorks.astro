---
const steps = [
  {
    number: '1',
    title: 'Sign up',
    description: 'Create a free account in seconds. No credit card required.',
    icon: '🚀',
  },
  {
    number: '2',
    title: 'Start capturing',
    description: 'Use the Chrome extension or web app to save insights anywhere.',
    icon: '✏️',
  },
  {
    number: '3',
    title: 'Learn better',
    description: 'Find and review your insights anytime with powerful search.',
    icon: '📚',
  },
];
---
<section id="how-it-works" class="py-24 bg-surfaceAlt dark:bg-[#0f0e0d] relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0">
    <div class="absolute top-1/2 left-0 w-96 h-96 bg-accent/5 dark:bg-accent/5 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-blue-500/5 dark:bg-blue-500/5 rounded-full blur-[80px]"></div>
  </div>

  <div class="max-w-5xl mx-auto px-4 relative">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-primary dark:text-[#faf9f7]">
        How it works
      </h2>
      <p class="text-secondary dark:text-[#9a9590]">
        Three simple steps to start capturing insights
      </p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-6">
      {steps.map((step, i) => (
        <div class="relative group">
          {/* Card */}
          <div class="relative p-8 rounded-2xl bg-surface dark:bg-[#1a1917] border border-border dark:border-[#2d2b28] h-full transition-all duration-300 group-hover:-translate-y-2">
            {/* Number badge */}
            <div class="absolute -top-4 left-8 w-10 h-10 rounded-full bg-accent flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-accent/30">
              {step.number}
            </div>
            
            <div class="pt-4 text-center">
              <div class="text-4xl mb-4">{step.icon}</div>
              <h3 class="text-lg font-semibold mb-3 text-primary dark:text-[#faf9f7]">{step.title}</h3>
              <p class="text-sm text-secondary dark:text-[#9a9590]">{step.description}</p>
            </div>
          </div>
          
          {/* Connector line */}
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-1/2 -right-3 w-6 h-0.5 bg-gradient-to-r from-accent/50 dark:from-accent/50 to-transparent z-10">
              <svg class="absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>