---
const year = new Date().getFullYear();
---
<footer class="py-12 bg-surface dark:bg-[#0f0e0d] border-t border-border dark:border-[#2d2b28]">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-2xl font-display text-primary dark:text-[#faf9f7]">Rwote</div>
      <div class="flex gap-6 text-sm">
        <a href="/privacy" class="text-secondary dark:text-[#9a9590] hover:text-primary dark:hover:text-[#faf9f7] transition-colors">Privacy</a>
        <a href="/terms" class="text-secondary dark:text-[#9a9590] hover:text-primary dark:hover:text-[#faf9f7] transition-colors">Terms</a>
        <a href="/refund" class="text-secondary dark:text-[#9a9590] hover:text-primary dark:hover:text-[#faf9f7] transition-colors">Refunds</a>
      </div>
      <p class="text-sm text-secondary dark:text-[#9a9590]">© {year} Rwote</p>
    </div>
  </div>
</footer>
