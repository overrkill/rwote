---
const year = new Date().getFullYear();
---
<footer class="py-12 mt-20 bg-surface border-t border-border">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-2xl font-display text-primary">Rwote</div>
      <div class="flex gap-6 text-sm">
        <a href="/privacy" class="text-secondary hover:text-primary transition-colors">Privacy</a>
        <a href="/terms" class="text-secondary hover:text-primary transition-colors">Terms</a>
        <a href="/refund" class="text-secondary hover:text-primary transition-colors">Refunds</a>
      </div>
      <p class="text-sm text-secondary">© {year} Rwote</p>
    </div>
  </div>
</footer>
