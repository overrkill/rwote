---
---
<header class="sticky top-0 z-50 backdrop-blur-md bg-bg/80 dark:bg-[#0f0e0d]/80 border-b border-border dark:border-border-dark">
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-3xl font-display text-primary-dark dark:text-[#faf9f7]">Rwote</a>
    <nav class="flex items-center gap-4">
      <a href="/blog" class="text-sm text-secondary-dark dark:text-[#9a9590] hover:text-primary-dark dark:hover:text-[#faf9f7] transition-colors">Blog</a>
      <a href="/auth/login" class="text-sm text-secondary-dark dark:text-[#9a9590] hover:text-primary-dark dark:hover:text-[#faf9f7] transition-colors">Sign In</a>
      <button id="theme-toggle" class="p-2 rounded-lg bg-surfaceAlt-dark dark:bg-[#252422] hover:bg-surface-dark dark:hover:bg-[#1a1917] transition-colors" title="Toggle theme">
        <svg id="sun-icon" class="w-5 h-5 hidden dark:block text-[#faf9f7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
        </svg>
        <svg id="moon-icon" class="w-5 h-5 block dark:hidden text-[#6b6560]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
        </svg>
      </button>
      <a href="/auth/register" class="px-4 py-2 rounded-full font-semibold text-sm bg-accent text-white hover:opacity-85 transition-opacity">
        Get Started
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  
  toggle?.addEventListener('click', () => {
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
